  "publicApiSurface": [
    "RfxConfig - Native .rfx config file format",
    "Pipeline - Core pipeline structure with blocks and settings",
    "Block - Individual pipeline block with type and settings",
    "BlockType - 50+ block types (HttpRequest, ParseJSON, KeyCheck, etc.)",
    "BlockSettings - Type-specific settings for each block",
    "CLI args: --config, --wordlist, --threads, --proxies, --outfile",
    "IPC commands: config operations, job management, block tree, runner control",
    "Plugin interface: FFI-based plugin system",
    "Import formats: .rfx, .svb, .opk, .loli",
